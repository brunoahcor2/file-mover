# --- ESPECÍFICOS DO USUÁRIO ---
/data/
/logs/
*.log

# --- COMPILAÇÃO E OUTPUT (JAMais versionar) ---
target/
build/
out/
bin/
*.class
*.cljs
*.out

# --- ARQUIVOS DE EMPACOTAMENTO ---
*.jar
*.war
*.ear
*.zip
*.tar.gz
# Exceção: manter o wrapper do Maven/Gradle para builds portáteis
!**/gradle-wrapper.jar
!**/maven-wrapper.jar

# --- INTELLIJ IDEA ---
.idea/
*.iml
*.iws
*.ipr
out/
# Se você trabalha em time, as vezes ignora-se a pasta .idea inteira
# ou mantém-se apenas o que for compartilhado (como code styles).

# --- ECLIPSE ---
.metadata/
.project
.classpath
.settings/
*.launch
.factorypath

# --- VISUAL STUDIO CODE ---
.vscode/
.history/

# --- GERENCIAMENTO DE DEPENDÊNCIAS ---
