.gradle/
.m2/

# --- SEGURANÇA E AMBIENTE (CRÍTICO) ---
.env
.env.local
*.jks
*.p12
*.key
*.pem
*.pub

# --- SISTEMA OPERACIONAL ---
.DS_Store
Thumbs.db
desktop.ini
